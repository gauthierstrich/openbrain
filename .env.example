# OpenBrain Core V2.1 — Configuration Simple
# ---------------------------------------------------------------------

# ─── Moteur (Recommandé: gemini-3-flash-preview)
GEMINI_MODEL=gemini-3-flash-preview

# ─── Authentification
# Note: PAS de GOOGLE_API_KEY. 
# Exécutez 'gemini login' dans votre terminal avant de lancer le bot.

# ─── Stockage
# Chemin absolu vers vos agents
BRAIN_STORAGE_PATH="~/Documents/OpenBrain"

# ─── Sécurité
# Votre ID numérique Telegram (ex: @userinfobot)
ALLOWED_USER_ID=your_telegram_numeric_id

# ─── Tokens Telegram (Un par agent)
# Format : TELEGRAM_TOKEN_NOMAGENT
TELEGRAM_TOKEN_ARCHITECT=your_architect_bot_token_here
TELEGRAM_TOKEN_PERSONAL=your_personal_bot_token_here
