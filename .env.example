# ─── Moteur ───
GEMINI_MODEL=gemini-3-flash-preview

# ─── Stockage ───
BRAIN_STORAGE_PATH="~/Documents/Second Brain/OpenBrain"

# ─── Sécurité ───
ALLOWED_USER_ID=your_telegram_numeric_id

# ─── Tokens Telegram (Un par agent) ───
# La clé doit suivre le format TELEGRAM_TOKEN_NOMAGENT
TELEGRAM_TOKEN_PERSONAL=your_personal_bot_token_here
TELEGRAM_TOKEN_MATH=your_math_bot_token_here

# ─── Recherche Sémantique (Optionnel) ───
# Clé API gratuite : https://aistudio.google.com/apikey
# Active les embeddings vectoriels pour la recherche dans la mémoire.
# Sans cette clé, le système fonctionne en mode mots-clés uniquement (FTS5).
# GOOGLE_API_KEY=your_api_key_here
