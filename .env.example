# TELEGRAM CONFIG
# Obtenez votre token via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=VOTRE_TOKEN_ICI

# SECURITY
# Votre ID Telegram personnel (utilisez /start pour le connaître)
ALLOWED_USER_ID=VOTRE_ID_TELEGRAM

# STORAGE CONFIG
# Chemin vers votre Second Brain Local (OpenBrain storage)
# Supporte l'utilisation de ~ pour le dossier Home (ex: ~/Documents/OpenBrain)
BRAIN_STORAGE_PATH=~/Documents/Second Brain/OpenBrain
